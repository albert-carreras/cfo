# cfo production stack (docker-compose.server.yml). Copy to `.env` on the host.
# Real values never enter git — only this template is committed.

# Postgres. The data lives in an external docker volume (cfo_postgres_data);
# these just define the role/db inside it. Use a long random password.
POSTGRES_DB=cfo
POSTGRES_USER=cfo
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# The app + migrations reach Postgres over the compose network (`db` service).
# The password here MUST match POSTGRES_PASSWORD above.
DATABASE_URL=postgresql://cfo:change-me-to-a-long-random-string@db:5432/cfo

# The voice (Phase 4 Ask layer) — the one egress off the tailnet. Optional:
# leave unset and Ask shows "unavailable"; everything deterministic still runs.
# OPENAI_API_KEY=sk-...

# Optional push notifications (ntfy) — the only other egress off the tailnet.
# Pings on status transitions, off-cycle material changes, feed failures and
# published reviews. Public topics are guessable: payloads stay coarse by
# design (labels/percents/months, never € amounts), but pick a hard-to-guess
# topic anyway. Leave unset to disable.
# NTFY_URL=https://ntfy.sh/your-topic

# Tailscale node — gives cfo its own MagicDNS name: https://cfo.<tailnet>.ts.net
# Create a reusable, pre-approved auth key (optionally tagged) at:
#   https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxxxxxx

# Where the app is reachable on your tailnet. Read by ./stack (the deploy
# "Ready at" line and ./stack ready); only this one key is read from .env.
CFO_PUBLIC_URL=https://cfo.your-tailnet.ts.net
